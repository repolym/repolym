                                        const num = typeof value === 'number' ? value : Number(value)
                                        return [`${toPersianDigits(Math.round(num))} دقیقه`, 'میانگین ۷ روزه']
                                    }}
                                    labelFormatter={(d) => formatDateShort(d as string)}
                                />
                                <Line
